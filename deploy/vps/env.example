# Copy to deploy/vps/.env on the VPS and replace every CHANGE_ME value.
# Generate tokens: openssl rand -hex 24

MCP_STATE_TOKEN=CHANGE_ME_state_token
MCP_COP_TOKEN=CHANGE_ME_cop_token
MCP_THIEF_TOKEN=CHANGE_ME_thief_token
MCP_REVOKED_TOKENS=

# Public URLs your opponent will call (use your VPS IP or domain).
MCP_COP_URL=http://136.112.135.83:8001
MCP_THIEF_URL=http://136.112.135.83:8002
