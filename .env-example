# .env-example — T-P0-04
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── LLM Provider ────────────────────────────────────────────────────────────
# API key for the configured LLM provider (OpenAI / Anthropic / Gemini, etc.)
LLM_API_KEY=

# ── MCP Server Tokens ────────────────────────────────────────────────────────
# Bearer tokens used by the orchestrator to authenticate against each MCP server.
MCP_COP_TOKEN=
MCP_THIEF_TOKEN=
# Optional comma-separated tokens to reject on server startup after rotation.
MCP_REVOKED_TOKENS=
# Optional test token expected to be rejected by cop-thief-verify-cloud.
MCP_TEST_REVOKED_TOKEN=

# ── Cloud MCP runtime ────────────────────────────────────────────────────────
# SERVER_ROLE selects the role for the generic cloud entrypoint: cop or thief.
SERVER_ROLE=
# PORT is normally injected by the cloud provider; MCP_HOST defaults to 0.0.0.0.
PORT=
MCP_HOST=

# ── Gmail API Credentials ────────────────────────────────────────────────────
# Choose ONE of the following auth methods (comment out the others):

# Option A — App password (simplest for dev)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Option B — OAuth 2.0 (path to credentials JSON downloaded from Google Console)
# GMAIL_CREDENTIALS_JSON=path/to/credentials.json
# GMAIL_TOKEN_JSON=path/to/token.json

# Option C — Service account key file
# GMAIL_SERVICE_ACCOUNT_JSON=path/to/service_account.json

# ── Optional overrides ───────────────────────────────────────────────────────
# Override the config file location (default: config/config.yaml)
# CONFIG_PATH=config/config.yaml
